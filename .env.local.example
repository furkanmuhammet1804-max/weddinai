# =============================================================
# WeddinAI — Ortam Değişkenleri (örnek)
# Bu dosyayı `.env.local` olarak kopyalayın ve değerleri doldurun.
#   Copy-Item .env.local.example .env.local
# Vercel'de aynı değişkenleri Project Settings → Environment Variables'a girin.
# =============================================================

# ---- Supabase (zorunlu) ----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# service_role anahtarı YALNIZCA sunucuda kullanılır; tarayıcıya sızdırmayın.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---- Oturum imzalama sırları (zorunlu) ----
# Rastgele üretin: `openssl rand -base64 32`
ADMIN_SESSION_SECRET=<rastgele-32-bayt-base64>
ODA_SESSION_SECRET=<rastgele-32-bayt-base64>

# ---- Hassas veri şifreleme (zorunlu) — AES-256-GCM ----
# Tam 32 bayt olmalı. Üretim: `openssl rand -base64 32` (44 karakter base64)
# veya `openssl rand -hex 32` (64 karakter hex).
APP_ENCRYPTION_KEY=<32-bayt-base64-veya-hex>

# ---- Admin girişi (zorunlu) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<güçlü-parola>

# ---- AI sağlayıcı (Gemini) ----
# Anahtar yoksa AI uçları "servis yanıt veremedi" döner; site geri kalanı çalışır.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=<gemini-api-key>
# Opsiyonel — varsayılan: gemini
AI_PROVIDER=gemini

# ---- Cron koruması (Vercel Cron için zorunlu) ----
# /api/cron/temizlik bu sır ile yetkilendirilir.
CRON_SECRET=<rastgele-uzun-deger>

# ---- Genel site adresi (paylaşılan davetiye linkleri için) ----
# Admin panel önizleme alanından açılsa bile müşteriye doğru kanonik link
# verilir. Sonunda / olmadan girin. Ayarlanmazsa www.weddinai.com varsayılır.
NEXT_PUBLIC_SITE_URL=https://www.weddinai.com
